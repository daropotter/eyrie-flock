{
	# ACME account email (optional but recommended for expiry notices).
	email {$ACME_EMAIL}
}

# Caddy obtains + auto-renews Let's Encrypt certs and proxies to each tool over
# the internal compose network. Each tool still enforces its own auth
# (e.g. OPENCODE_SERVER_PASSWORD, PAPERCLIP_AUTH_SECRET, …).
#
# Set HERMES_DOMAIN and OPENCLAW_DOMAIN in .env to activate companion domains.
{$OPENCODE_DOMAIN} {
	reverse_proxy opencode:4096
}

{$PAPERCLIP_DOMAIN} {
	reverse_proxy paperclip:3100
}

{$HERMES_DOMAIN} {
	reverse_proxy hermes:8642
}

{$OPENCLAW_DOMAIN} {
	reverse_proxy openclaw:18789
}
