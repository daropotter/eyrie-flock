#!/usr/bin/env bash
# Merge local-model provider entries into config/opencode.json based on .env flags.
set -euo pipefail

cd "$(dirname "$0")/.."

if [[ ! -f .env ]]; then
  echo "No .env found — run make setup or ./bin/onboard first." >&2
  exit 1
fi

# shellcheck disable=SC1091
set -a && source .env && set +a

CONFIG="config/opencode.json"
mkdir -p config models

python3 - "$CONFIG" <<'PY'
import json
import os
import sys
from pathlib import Path

config_path = Path(sys.argv[1])
providers: dict = {}

if os.getenv("LOCAL_OLLAMA_ENABLED") == "1":
    model = os.getenv("OLLAMA_DEFAULT_MODEL", "llama3.1")
    providers["ollama"] = {
        "npm": "@ai-sdk/openai-compatible",
        "options": {"baseURL": "http://ollama:11434/v1"},
        "models": {
            model: {"name": f"{model} (Ollama local)"},
        },
    }

if os.getenv("LOCAL_LMSTUDIO_ENABLED") == "1":
    model = os.getenv("LMSTUDIO_DEFAULT_MODEL", "local-model")
    providers["lmstudio"] = {
        "npm": "@ai-sdk/openai-compatible",
        "options": {"baseURL": "http://lmstudio:1234/v1"},
        "models": {
            model: {"name": "LM Studio (local)"},
        },
    }

if os.getenv("LOCAL_LLAMACPP_ENABLED") == "1":
    model = os.getenv("LLAMACPP_DEFAULT_MODEL", "qwen3-coder")
    providers["llama.cpp"] = {
        "npm": "@ai-sdk/openai-compatible",
        "options": {"baseURL": "http://llamacpp:8080/v1"},
        "models": {
            model: {"name": "llama.cpp (local)"},
        },
    }

if not providers:
    print("No LOCAL_*_ENABLED flags set — nothing to configure.")
    sys.exit(0)

config: dict = {}
if config_path.exists() and config_path.read_text().strip():
    config = json.loads(config_path.read_text())

config.setdefault("provider", {})
for key, value in providers.items():
    config["provider"][key] = value

config_path.write_text(json.dumps(config, indent=2) + "\n")
print(f"Updated {config_path} with: {', '.join(providers)}")
PY
