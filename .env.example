# Copy to .env and adjust:  cp .env.example .env

# --- File permissions ---
# Host UID/GID (check with `id -u` / `id -g`). This makes files in ./projects,
# ./config and ./data owned by you instead of root.
PUID=1000
PGID=1000

# --- Network ---
# 127.0.0.1 = localhost only (recommended when behind a reverse proxy).
# 0.0.0.0   = reachable on the whole LAN / externally (REQUIRES passwords!).
BIND_ADDR=127.0.0.1
PORT=4096

# --- Git / SSH ---
# Directory with the SSH key used inside containers for git (mounted read-only).
# `make setup` / `make ssh-key` generates a dedicated key in ./ssh (recommended,
# no need to copy your personal key). Set to ${HOME}/.ssh to reuse your own.
SSH_DIR=./ssh
# Token for git over HTTPS (optional).
GH_TOKEN=

# --- Shared AI provider API keys (optional) ---
# Onboard.sh configures API-key providers here. Subscription providers
# (OpenCode Go, Zen, Copilot, ChatGPT Plus, Claude Pro) are configured
# via 'make auth' or /connect inside the opencode TUI instead.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
TOGETHER_API_KEY=
HF_TOKEN=
MISTRAL_API_KEY=
FIREWORKS_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=

# ── opencode — AI coding agent (web UI + CLI) ──────────────────
# Server basic-auth. SET A PASSWORD if you expose this beyond localhost!
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=
# Version baked into the image (leave empty for latest).
OPENCODE_VERSION=latest
# Local models (Ollama, LM Studio, llama.cpp) need no API key — enable below
# then: make up-local-models
LOCAL_OLLAMA_ENABLED=
LOCAL_LMSTUDIO_ENABLED=
LOCAL_LLAMACPP_ENABLED=

# ── Agent CLIs (Claude Code, Cursor Agent) ─────────────────
# Pin a specific Claude Code version (leave empty for latest).
CLAUDECODE_VERSION=
# Cursor Agent API key — get one at https://cursor.com/settings
CURSOR_API_KEY=

# ── Caddy reverse proxy (make up-tls) ──────────────────────
# Domain pointing (A/AAAA) at this server; Caddy gets a Let's Encrypt cert for it.
# No domain? Use a wildcard-DNS host like 123-200-12-34.sslip.io
#
# Services are routed by path on the same domain:
#   /            → opencode
#   /paperclip/* → paperclip
#   /hermes/*    → hermes
#   /openclaw/*  → openclaw
OPENCODE_DOMAIN=
ACME_EMAIL=

# ── Headroom — token-saving proxy (make up-headroom) ───────
# Compresses context before it reaches the LLM (40–95% fewer input tokens).
HEADROOM_VERSION=latest
# Set to 1 to route OpenClaw (and any other HEADROOM_ENABLED-aware service)
# through the Headroom proxy. Set automatically by `make up-headroom` /
# `make up-headroom-all`; leave empty when running without Headroom.
HEADROOM_ENABLED=
# optimize (max compression) | cache (keep provider prefix cache stable) | audit | passthrough
HEADROOM_MODE=optimize
HEADROOM_LOG_LEVEL=INFO
# Also trim what the model writes back (output tokens): 1 = on, 0 = off.
HEADROOM_OUTPUT_SHAPER=0
# Port for the local dashboard / direct access (bound to 127.0.0.1).
HEADROOM_PORT=8787

# ── Paperclip — agent control plane (make up-paperclip) ────
# Self-hosted task board where agents pick up work and run in heartbeats.
# Deployment mode is set to "authenticated" automatically on first start,
# enabling admin invite (bootstrap-ceo) flow for first-user sign-in.
PAPERCLIP_VERSION=latest
PAPERCLIP_PORT=3100
# Stable secret for auth sessions. Leave empty and `make up-paperclip` fills it
# in for you, or set your own with:  openssl rand -hex 32
PAPERCLIP_AUTH_SECRET=
# External URL used for auth/callback/invite flows. Auto-set by 'onboard' when
# Caddy is configured — https://${OPENCODE_DOMAIN}/paperclip.
PAPERCLIP_PUBLIC_URL=

# ── Hermes Agent (make up-hermes) ──────────────────────────
# Self-improving AI agent with persistent memory, skills, and multi-platform
# messaging.
HERMES_VERSION=latest
# Gateway + web dashboard port (bound to BIND_ADDR, like other tools).
HERMES_PORT=8642
# Optional: auth token for the Hermes gateway API.
HERMES_AUTH_TOKEN=
# Public URL for external flows. Auto-set by 'onboard' when Caddy is configured.
HERMES_PUBLIC_URL=

# ── OpenClaw — agent gateway (make up-openclaw) ────────────

# ── OpenClaw — agent gateway (make up-openclaw) ────────────
# Always-on gateway that connects agents to chat channels and dispatches
# sessions. Only used when running with docker-compose.openclaw.yml.
OPENCLAW_VERSION=latest
# OPENCLAW_IMAGE=openclaw/openclaw:latest
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
# lan = reachable from the host/LAN (needed to open the Control UI); local = loopback only.
OPENCLAW_GATEWAY_BIND=lan
# Shared secret for the Control UI / CLI. Leave empty and `make up-openclaw`
# fills it in, or set your own with:  openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=
# Public URL for auth/callback flows. Auto-set by 'onboard' when Caddy is configured.
OPENCLAW_PUBLIC_URL=
# Timezone for the gateway container.
OPENCLAW_TZ=

# ── Local model servers ────────────────────────────────────
# Ollama
OLLAMA_VERSION=latest
OLLAMA_PORT=11434
OLLAMA_DEFAULT_MODEL=llama3.1
# Model pulled automatically on first start (ollama-init sidecar).
OLLAMA_PULL_MODEL=
# Set to 1 for NVIDIA GPU passthrough (needs NVIDIA Container Toolkit).
OLLAMA_USE_GPU=
# LM Studio (llmster headless preview image — CPU, x86_64)
LMSTUDIO_VERSION=cpu
LMSTUDIO_PORT=1234
LMSTUDIO_DEFAULT_MODEL=local-model
# llama.cpp — place a .gguf file in ./models/ and set LLAMACPP_MODEL to its filename
LLAMACPP_IMAGE_TAG=server
LLAMACPP_PORT=8080
LLAMACPP_MODEL=
LLAMACPP_DEFAULT_MODEL=qwen3-coder
