# Copy to .env and adjust:  cp .env.example .env

# --- File permissions ---
# Host UID/GID (check with `id -u` / `id -g`). This makes files in ./projects,
# ./config and ./data owned by you instead of root.
PUID=1000
PGID=1000

# --- Network ---
# 127.0.0.1 = localhost only (recommended when behind a reverse proxy).
# 0.0.0.0   = reachable on the whole LAN / externally (REQUIRES a password!).
BIND_ADDR=127.0.0.1
PORT=4096

# --- Security (server basic auth) ---
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=

# --- HTTPS via Caddy (make up-tls) ---
# Domain pointing (A/AAAA) at this server; Caddy gets a Let's Encrypt cert for it.
# No domain? Use a wildcard-DNS host like 123-200-12-34.sslip.io
OPENCODE_DOMAIN=
ACME_EMAIL=

# --- opencode version baked into the image ---
OPENCODE_VERSION=latest

# --- Git / SSH ---
# Directory with the SSH key used inside the container for git (mounted read-only).
# `make setup` / `make ssh-key` generates a dedicated key in ./ssh (recommended,
# no need to copy your personal key). Set to ${HOME}/.ssh to reuse your own.
SSH_DIR=./ssh
# Token for git over HTTPS (optional).
GH_TOKEN=

# --- Provider keys (optional) ---
# Usually it's easier to set these once via `opencode auth login` (stored in ./data),
# but you can also inject them via env:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# --- Headroom token-saving proxy (make up-headroom) ---
# Compresses context before it reaches the LLM (40–95% fewer input tokens).
# Only used when running with docker-compose.headroom.yml.
HEADROOM_VERSION=latest
# Set to 1 to route OpenClaw (and any other HEADROOM_ENABLED-aware service)
# through the Headroom proxy. Set automatically by `make up-headroom` /
# `make up-headroom-all`; leave empty when running without Headroom.
HEADROOM_ENABLED=
# optimize (max compression) | cache (keep provider prefix cache stable) | audit | passthrough
HEADROOM_MODE=optimize
HEADROOM_LOG_LEVEL=INFO
# Also trim what the model writes back (output tokens): 1 = on, 0 = off.
HEADROOM_OUTPUT_SHAPER=0
# Port for the local dashboard / direct access (bound to 127.0.0.1).
HEADROOM_PORT=8787

# --- Paperclip agent control plane (make up-paperclip) ---
# Self-hosted task board where agents pick up work and run in heartbeats.
# Only used when running with docker-compose.paperclip.yml.
PAPERCLIP_VERSION=latest
# Web board port (bound to BIND_ADDR, like opencode).
PAPERCLIP_PORT=3100
# Stable secret for auth sessions. Leave empty and `make up-paperclip` fills it
# in for you, or set your own with:  openssl rand -hex 32
PAPERCLIP_AUTH_SECRET=
# External URL used for auth/callback/invite flows. Set only if you reach the
# board on something other than http://localhost:${PAPERCLIP_PORT}
# (e.g. behind a reverse proxy or on a LAN IP).
PAPERCLIP_PUBLIC_URL=

# --- OpenClaw agent gateway (make up-openclaw) ---
# Always-on gateway that connects agents to chat channels and dispatches
# sessions. Only used when running with docker-compose.openclaw.yml.
# Pin a tag or point at Docker Hub (openclaw/openclaw) via OPENCLAW_IMAGE.
OPENCLAW_VERSION=latest
# OPENCLAW_IMAGE=openclaw/openclaw:latest
# Control UI + bridge ports (bound to BIND_ADDR, like opencode).
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
# lan = reachable from the host/LAN (needed to open the Control UI); local = loopback only.
OPENCLAW_GATEWAY_BIND=lan
# Shared secret for the Control UI / CLI. Leave empty and `make up-openclaw`
# fills it in, or set your own with:  openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=
# Timezone for the gateway container.
OPENCLAW_TZ=Europe/Warsaw
