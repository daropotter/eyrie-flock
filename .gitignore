# Secrets and local state
.env

# opencode persistence (API keys, sessions, config with secrets)
/data/*
!/data/.gitkeep
/config/*
!/config/.gitkeep

# Dedicated git SSH key generated by `make ssh-key`
/ssh/

# Mounted projects / external resources
/projects/*
!/projects/.gitkeep

# Cloudflare deploy node_modules (not excluded by /config/* pattern)
/cloudflare/node_modules/

# System junk
.DS_Store
